# Replace with your team's deployed backend URL (EC2 or Railway etc.)
REACT_APP_API_URL=http://localhost:5000/api

# Replace with your S3 bucket URL (your backend team will give this)
REACT_APP_S3_BASE_URL=https://your-bucket.s3.amazonaws.com

# CloudFront CDN URL (optional - if your team sets it up)
REACT_APP_CDN_URL=https://your-cloudfront-id.cloudfront.net
